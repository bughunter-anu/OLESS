@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Subjects";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Manage Subjects</h1>
        <div class="breadcrumb">
            <a href="/Admin">Admin</a>
            <span class="breadcrumb-separator">/</span>
            <span>Subjects</span>
        </div>
    </div>
    <button class="btn btn-primary" onclick="showCreateModal()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Add Subject
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Subject Name</th>
                    <th>Description</th>
                    <th>Credits</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subject in (List<OLESS.Models.Subject>)ViewBag.Subjects)
                {
                    <tr>
                        <td>@subject.SubjectID</td>
                        <td><strong>@subject.SubjectCode</strong></td>
                        <td>@subject.SubjectName</td>
                        <td>@(subject.Description?.Length > 50 ? subject.Description.Substring(0, 50) + "..." : subject.Description)</td>
                        <td>@subject.Credits</td>
                        <td>
                            @if (subject.IsActive)
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactive</span>
                            }
                        </td>
                        <td class="table-actions">
                            <button class="btn btn-sm btn-outline" onclick="editSubject(@subject.SubjectID, '@subject.SubjectCode', '@subject.SubjectName', '@subject.Description', @subject.Credits, @subject.IsActive.ToString().ToLower())">Edit</button>
                            <form method="post" action="/Admin/DeleteSubject" style="display: inline;">
                                <input type="hidden" name="subjectId" value="@subject.SubjectID" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="subjectModal">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title" id="modalTitle">Add Subject</h3>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body">
            <form id="subjectForm" method="post">
                <input type="hidden" id="editSubjectId" name="subjectId" />
                <div id="createFields">
                    <div class="form-group">
                        <label class="form-label">Subject Code</label>
                        <input type="text" name="subjectCode" class="form-control" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Subject Name</label>
                    <input type="text" name="subjectName" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Credits</label>
                    <input type="number" name="credits" class="form-control" value="3" min="1" max="10" required>
                </div>
                <div class="form-group" id="activeField" style="display: none;">
                    <label class="form-check">
                        <input type="checkbox" name="isActive" checked>
                        <span>Active</span>
                    </label>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline" onclick="closeModal()">Cancel</button>
            <button type="button" class="btn btn-primary" onclick="submitForm()">Save</button>
        </div>
    </div>
</div>

<script>
function showCreateModal() {
    document.getElementById('modalTitle').textContent = 'Add Subject';
    document.getElementById('subjectForm').action = '/Admin/CreateSubject';
    document.getElementById('createFields').style.display = 'block';
    document.getElementById('activeField').style.display = 'none';
    document.getElementById('subjectForm').reset();
    document.getElementById('editSubjectId').value = '';
    document.getElementById('userModal').classList.add('active');
}

function editSubject(id, code, name, description, credits, isActive) {
    document.getElementById('modalTitle').textContent = 'Edit Subject';
    document.getElementById('subjectForm').action = '/Admin/UpdateSubject';
    document.getElementById('createFields').style.display = 'none';
    document.getElementById('activeField').style.display = 'block';
    document.getElementById('editSubjectId').value = id;
    
    document.querySelector('input[name="subjectName"]').value = name;
    document.querySelector('textarea[name="description"]').value = description || '';
    document.querySelector('input[name="credits"]').value = credits;
    document.querySelector('input[name="isActive"]').checked = isActive;
    
    document.getElementById('subjectModal').classList.add('active');
}

function closeModal() {
    document.getElementById('subjectModal').classList.remove('active');
}

function submitForm() {
    document.getElementById('subjectForm').submit();
}
</script>
