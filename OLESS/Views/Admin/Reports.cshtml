@{
    Layout = "_Layout";
    ViewData["Title"] = "Reports";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Reports & Analytics</h1>
        <div class="breadcrumb">
            <a href="/Admin">Admin</a>
            <span class="breadcrumb-separator">/</span>
            <span>Reports</span>
        </div>
    </div>
</div>

<div class="grid-2 mb-4">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Filter by Subject</h3>
        </div>
        <div class="card-body" style="padding: 1rem;">
            <select id="reportSubject" class="form-control" onchange="loadSubjectReport()">
                <option value="">Select Subject</option>
                @foreach (var subject in (List<OLESS.Models.Subject>)ViewBag.Subjects)
                {
                    <option value="@subject.SubjectID">@subject.SubjectName</option>
                }
            </select>
        </div>
    </div>
</div>

<div class="stats-grid" id="subjectStats" style="display: none;">
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
            </svg>
        </div>
        <div class="stat-content">
            <h3 id="totalStudents">0</h3>
            <p>Total Students</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
        </div>
        <div class="stat-content">
            <h3 id="passedStudents">0</h3>
            <p>Passed</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="15" y1="9" x2="9" y2="15"></line>
                <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
        </div>
        <div class="stat-content">
            <h3 id="failedStudents">0</h3>
            <p>Failed</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
                <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
            </svg>
        </div>
        <div class="stat-content">
            <h3 id="avgPercentage">0%</h3>
            <p>Average Score</p>
        </div>
    </div>
</div>

<div class="grid-2" style="margin-top: 2rem;">
    <div class="card" id="passedCard" style="display: none;">
        <div class="card-header">
            <h3 class="card-title">Passed Students</h3>
        </div>
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Score</th>
                        <th>Percentage</th>
                        <th>Grade</th>
                    </tr>
                </thead>
                <tbody id="passedTable"></tbody>
            </table>
        </div>
    </div>
    
    <div class="card" id="failedCard" style="display: none;">
        <div class="card-header">
            <h3 class="card-title">Failed Students</h3>
        </div>
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Score</th>
                        <th>Percentage</th>
                        <th>Grade</th>
                    </tr>
                </thead>
                <tbody id="failedTable"></tbody>
            </table>
        </div>
    </div>
</div>

<script>
function loadSubjectReport() {
    var subjectId = document.getElementById('reportSubject').value;
    
    if (!subjectId) {
        document.getElementById('subjectStats').style.display = 'none';
        document.getElementById('passedCard').style.display = 'none';
        document.getElementById('failedCard').style.display = 'none';
        return;
    }
    
    Promise.all([
        fetch('/Admin/GetSubjectResults?subjectId=' + subjectId).then(r => r.json()),
        fetch('/Admin/GetPassedStudents?subjectId=' + subjectId).then(r => r.json()),
        fetch('/Admin/GetFailedStudents?subjectId=' + subjectId).then(r => r.json())
    ]).then(([results, passed, failed]) => {
        document.getElementById('subjectStats').style.display = 'grid';
        document.getElementById('passedCard').style.display = 'block';
        document.getElementById('failedCard').style.display = 'block';
        
        var passedCount = passed.length;
        var failedCount = failed.length;
        var total = passedCount + failedCount;
        var avgPercentage = total > 0 ? ((passed.reduce((sum, r) => sum + r.Percentage, 0) + failed.reduce((sum, r) => sum + r.Percentage, 0)) / total).toFixed(1) : 0;
        
        document.getElementById('totalStudents').textContent = total;
        document.getElementById('passedStudents').textContent = passedCount;
        document.getElementById('failedStudents').textContent = failedCount;
        document.getElementById('avgPercentage').textContent = avgPercentage + '%';
        
        var passedTable = document.getElementById('passedTable');
        passedTable.innerHTML = passed.map(r => `
            <tr>
                <td>${r.StudentName}</td>
                <td>${r.CorrectAnswers}/${r.TotalQuestions}</td>
                <td>${r.Percentage}%</td>
                <td><span class="badge badge-success">${r.Grade}</span></td>
            </tr>
        `).join('') || '<tr><td colspan="4" class="text-center">No passed students</td></tr>';
        
        var failedTable = document.getElementById('failedTable');
        failedTable.innerHTML = failed.map(r => `
            <tr>
                <td>${r.StudentName}</td>
                <td>${r.CorrectAnswers}/${r.TotalQuestions}</td>
                <td>${r.Percentage}%</td>
                <td><span class="badge badge-danger">${r.Grade}</span></td>
            </tr>
        `).join('') || '<tr><td colspan="4" class="text-center">No failed students</td></tr>';
    });
}
</script>
