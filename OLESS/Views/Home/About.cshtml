@{
    Layout = "_Layout";
    ViewData["Title"] = "About OLESS";
}

<section style="background: white; padding: 4rem 0;">
    <div class="container">
        <div style="text-align: center; max-width: 800px; margin: 0 auto;">
            <h1>About OLESS</h1>
            <p style="font-size: 1.125rem; color: #6b7280; margin-bottom: 3rem;">
                The Online Examination Security System (OLESS) is a comprehensive platform designed to automate 
                the examination process for educational institutions.
            </p>
        </div>

        <div class="grid-3">
            <div class="card feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h3>Security First</h3>
                <p>Role-based access control, encrypted passwords, and SQL injection prevention.</p>
            </div>
            <div class="card feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                </div>
                <h3>Time Management</h3>
                <p>Timer-based exams with auto-submit functionality and time tracking.</p>
            </div>
            <div class="card feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                </div>
                <h3>Question Bank</h3>
                <p>Organized question bank with MCQ and True/False types across difficulty levels.</p>
            </div>
        </div>

        <div style="margin-top: 4rem; text-align: center;">
            <h2>Key Features</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-top: 2rem; text-align: left;">
                <div style="padding: 1rem;">
                    <h4>Student Module</h4>
                    <ul style="color: #6b7280; padding-left: 1.5rem;">
                        <li>Secure registration and login</li>
                        <li>Subject and difficulty selection</li>
                        <li>Random question sets</li>
                        <li>Instant results and feedback</li>
                    </ul>
                </div>
                <div style="padding: 1rem;">
                    <h4>Admin Module</h4>
                    <ul style="color: #6b7280; padding-left: 1.5rem;">
                        <li>Complete user management</li>
                        <li>Question bank management</li>
                        <li>Subject and topic organization</li>
                        <li>Comprehensive reports</li>
                    </ul>
                </div>
                <div style="padding: 1rem;">
                    <h4>Security Features</h4>
                    <ul style="color: #6b7280; padding-left: 1.5rem;">
                        <li>Password hashing</li>
                        <li>Session management</li>
                        <li>SQL injection prevention</li>
                        <li>Role-based permissions</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
