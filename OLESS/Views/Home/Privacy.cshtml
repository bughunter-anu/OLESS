@{
    Layout = "_Layout";
    ViewData["Title"] = "Privacy Policy";
}

<section style="background: white; padding: 4rem 0;">
    <div class="container">
        <div style="max-width: 800px; margin: 0 auto;">
            <h1>Privacy Policy</h1>
            <p style="color: #6b7280; margin-bottom: 2rem;">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

            <div style="line-height: 1.8; color: #374151;">
                <h2>1. Information We Collect</h2>
                <p>We collect information you provide directly to us, including:</p>
                <ul style="padding-left: 2rem;">
                    <li>Personal information (name, email, username)</li>
                    <li>Examination data and results</li>
                    <li>Usage data and analytics</li>
                </ul>

                <h2>2. How We Use Your Information</h2>
                <p>We use the information we collect to:</p>
                <ul style="padding-left: 2rem;">
                    <li>Provide and maintain our examination services</li>
                    <li>Generate examination results and reports</li>
                    <li>Improve our services and user experience</li>
                    <li>Communicate with you about your account</li>
                </ul>

                <h2>3. Data Security</h2>
                <p>
                    We implement appropriate technical and organizational measures to protect your personal information, 
                    including password hashing and secure database access.
                </p>

                <h2>4. Data Retention</h2>
                <p>
                    We retain your information for as long as your account is active or as needed to provide you services. 
                    We may retain certain information as required by law.
                </p>

                <h2>5. Your Rights</h2>
                <p>You have the right to:</p>
                <ul style="padding-left: 2rem;">
                    <li>Access your personal information</li>
                    <li>Correct inaccurate data</li>
                    <li>Request deletion of your data</li>
                    <li>Opt out of communications</li>
                </ul>

                <h2>6. Contact Us</h2>
                <p>
                    If you have any questions about this Privacy Policy, please contact us at privacy@oless.edu.
                </p>
            </div>
        </div>
    </div>
</section>
